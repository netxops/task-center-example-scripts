{
  "version": "2026-03-31",
  "source_repository": {
    "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
    "repo_branch": "main"
  },
  "templates": [
    {
      "name": "task-center-shell-system-deep-inspection",
      "description": "系统深度巡检模板。适合对 Linux 主机做更全面的巡检、摸底和故障前后对比。",
      "app_type": "shell",
      "variable_set_name": "task-center-shell-inspection-defaults",
      "playbook_path": "shell/system-deep-inspection/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-shell-system-quick-snapshot",
      "description": "系统快速信息抓取模板。适合在排障开始阶段快速确认主机当前状态。",
      "app_type": "shell",
      "playbook_path": "shell/system-quick-snapshot/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-shell-batch-file-transfer",
      "description": "批量文件上下发模板。适合一对多推送文件，或从多台主机回收日志与配置。",
      "app_type": "shell",
      "variable_set_name": "task-center-shell-transfer-defaults",
      "playbook_path": "shell/batch-file-transfer/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main",
      "arguments": "./package.tar.gz /tmp/releases"
    },
    {
      "name": "task-center-shell-file-backup-rotate",
      "description": "本机文件备份与轮转模板。适合备份关键目录、配置文件和应用产物。",
      "app_type": "shell",
      "variable_set_name": "task-center-shell-backup-defaults",
      "playbook_path": "shell/file-backup-rotate/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main",
      "arguments": "/etc/hosts /etc/resolv.conf"
    },
    {
      "name": "task-center-shell-cron-job-manage",
      "description": "Shell cron 管理模板。适合快速开通、更新或下线系统定时任务。",
      "app_type": "shell",
      "playbook_path": "shell/cron-job-manage/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-shell-periodic-pcap",
      "description": "周期性抓包模板。适合按接口、过滤条件和轮转周期持续抓包。",
      "app_type": "shell",
      "variable_set_name": "task-center-shell-pcap-defaults",
      "playbook_path": "shell/periodic-pcap/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-shell-linux-baseline-report",
      "description": "Linux 主机基线巡检模板。适合在 Agent 纳管后快速摸底主机资源、进程与端口情况。",
      "app_type": "shell",
      "variable_set_name": "task-center-shell-linux-baseline-defaults",
      "playbook_path": "shell/linux-baseline-report/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-shell-http-endpoint-check",
      "description": "HTTP/HTTPS 健康检查模板。适合做发布后巡检、健康探针和外部接口连通性检查。",
      "app_type": "shell",
      "variable_set_name": "task-center-shell-http-check-defaults",
      "playbook_path": "shell/http-endpoint-check/run.sh",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main",
      "arguments": "https://example.com/healthz"
    },
    {
      "name": "task-center-ansible-linux-deep-inspection",
      "description": "Ansible 深度巡检模板。适合对一批 Linux 主机统一采集失败服务、端口、热点进程和错误日志。",
      "app_type": "ansible",
      "variable_set_name": "task-center-ansible-linux-deep-inspection-defaults",
      "playbook_path": "ansible/linux-deep-inspection/site.yml",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-ansible-batch-file-transfer",
      "description": "Ansible 批量文件上下发模板。适合把文件推到多台主机，或把多台主机上的文件打包回收。",
      "app_type": "ansible",
      "variable_set_name": "task-center-ansible-batch-transfer-defaults",
      "playbook_path": "ansible/batch-file-transfer/site.yml",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-ansible-file-backup-rotate",
      "description": "Ansible 批量文件备份模板。适合对多台主机上的关键目录和配置文件做归档备份。",
      "app_type": "ansible",
      "variable_set_name": "task-center-ansible-file-backup-defaults",
      "playbook_path": "ansible/file-backup-rotate/site.yml",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-ansible-cron-job-manage",
      "description": "Ansible cron 管理模板。适合在多台 Linux 主机上统一创建、更新或删除计划任务。",
      "app_type": "ansible",
      "variable_set_name": "task-center-ansible-cron-job-defaults",
      "playbook_path": "ansible/cron-job-manage/site.yml",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-ansible-linux-baseline",
      "description": "Ansible Linux 巡检模板。适合统一采集主机事实、磁盘和热点进程信息。",
      "app_type": "ansible",
      "variable_set_name": "task-center-ansible-linux-baseline-defaults",
      "playbook_path": "ansible/linux-baseline/site.yml",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-ansible-linux-service-status",
      "description": "Ansible 服务状态检查模板。适合检查 sshd、docker、nginx、kubelet 等关键服务。",
      "app_type": "ansible",
      "variable_set_name": "task-center-ansible-service-status-defaults",
      "playbook_path": "ansible/linux-service-status/site.yml",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main"
    },
    {
      "name": "task-center-terraform-aws-s3-secure-bucket",
      "description": "Terraform AWS S3 安全桶模板。适合创建带版本控制、加密和公网阻断的对象存储桶。",
      "app_type": "terraform",
      "playbook_path": "terraform/aws-s3-secure-bucket-starter",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main",
      "arguments": "[\"-input=false\",\"-var=aws_region=us-east-1\",\"-var=bucket_name=change-me-oneops-secure-bucket\"]"
    },
    {
      "name": "task-center-terraform-aws-ec2-instance",
      "description": "Terraform AWS EC2 单机模板。适合作为云主机交付、临时跳板机或运维作业节点的起步模板。",
      "app_type": "terraform",
      "playbook_path": "terraform/aws-ec2-instance-starter",
      "repo_url": "https://github.com/netxops/task-center-example-scripts.git",
      "repo_branch": "main",
      "arguments": "[\"-input=false\",\"-var=aws_region=us-east-1\",\"-var=name=oneops-demo-ec2\"]"
    },
    {
      "name": "task-center-tofu-aws-s3-secure-bucket",
